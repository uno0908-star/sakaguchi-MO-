<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>TMS 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Oswald:wght@300;400;600;700&family=Noto+Sans+JP:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════
   RESET & BASE
══════════════════════════════════════ */
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;overscroll-behavior:none;}
body{
  background:#060608;color:#efefef;
  font-family:'Noto Sans JP',sans-serif;font-weight:300;
  -webkit-font-smoothing:antialiased;
  user-select:none;
}

/* ══ CSS VARIABLES ══ */
:root{
–red:#e8000d;–red2:#ff2030;–orange:#ff6a00;
–gold:#f0c040;–purple:#b06aff;–green:#00e676;–blue:#40c4ff;
–bg:#060608;–bg2:#0a0a0e;–card:#0e0e14;–card2:#13131c;
–border:#1e1e2a;–muted:#55556a;
–nav-h:64px;–status-h:44px;
–font-rock:‘Black Ops One’,cursive;
–font-label:‘Oswald’,sans-serif;
–font-body:‘Noto Sans JP’,sans-serif;
}

/* ══ SCROLLBAR ══ */
::-webkit-scrollbar{width:2px;height:2px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(–red);border-radius:2px;}

/* ══════════════════════════════════════
APP SHELL
══════════════════════════════════════ */
#app{
position:fixed;inset:0;
display:flex;flex-direction:column;
max-width:430px;margin:0 auto;
background:var(–bg);
box-shadow:0 0 60px rgba(0,0,0,.8);
overflow:hidden;
}

/* ── STATUS BAR ── */
#status-bar{
height:var(–status-h);flex-shrink:0;
background:rgba(6,6,8,.95);
display:flex;align-items:center;justify-content:space-between;
padding:0 20px;
border-bottom:1px solid var(–border);
position:relative;z-index:100;
}
.sb-time{font-family:var(–font-label);font-size:15px;font-weight:700;letter-spacing:1px;}
.sb-right{display:flex;align-items:center;gap:6px;}
.sb-icon{font-size:12px;color:var(–muted);}
.sb-signal{display:flex;gap:2px;align-items:flex-end;}
.sb-signal span{width:3px;background:var(–muted);border-radius:1px;}
.sb-signal span:nth-child(1){height:4px;}
.sb-signal span:nth-child(2){height:7px;}
.sb-signal span:nth-child(3){height:10px;}
.sb-battery{
width:22px;height:12px;border:1.5px solid var(–muted);
border-radius:2px;position:relative;
display:flex;align-items:center;padding:1.5px;
}
.sb-battery::after{
content:’’;position:absolute;right:-4px;top:50%;transform:translateY(-50%);
width:2px;height:5px;background:var(–muted);border-radius:0 1px 1px 0;
}
.sb-battery-fill{flex:1;height:100%;background:var(–green);border-radius:1px;}

/* ── BOTTOM NAV ── */
#bottom-nav{
height:var(–nav-h);flex-shrink:0;
background:rgba(8,8,12,.96);
backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
border-top:1px solid var(–border);
display:flex;align-items:stretch;
position:relative;z-index:100;
padding-bottom:env(safe-area-inset-bottom,0px);
}
.nav-item{
flex:1;display:flex;flex-direction:column;align-items:center;
justify-content:center;gap:3px;
color:var(–muted);cursor:pointer;
transition:color .2s;position:relative;
padding:8px 0;
}
.nav-item.active{color:var(–red);}
.nav-item.active::before{
content:’’;position:absolute;top:0;left:50%;transform:translateX(-50%);
width:36px;height:2px;background:var(–red);border-radius:0 0 2px 2px;
}
.nav-icon{font-size:20px;line-height:1;transition:transform .2s;}
.nav-item.active .nav-icon{transform:scale(1.15);}
.nav-label{font-family:var(–font-label);font-size:9px;letter-spacing:1.5px;font-weight:600;}

/* ── SCREEN CONTAINER ── */
#screens{
flex:1;overflow:hidden;position:relative;
}
.screen{
position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;
overscroll-behavior-y:contain;
opacity:0;pointer-events:none;
transform:translateX(30px);
transition:opacity .28s cubic-bezier(.4,0,.2,1),transform .28s cubic-bezier(.4,0,.2,1);
-webkit-overflow-scrolling:touch;
}
.screen.active{
opacity:1;pointer-events:auto;
transform:translateX(0);
}
.screen.exit-left{transform:translateX(-30px);opacity:0;}
.screen-pad{padding:16px 16px 24px;}

/* ══════════════════════════════════════
HOME SCREEN
══════════════════════════════════════ */
#screen-home{}

/* HERO CARD */
.home-hero{
position:relative;overflow:hidden;
border-radius:16px;
background:linear-gradient(145deg,#1c0003 0%,#0e0e18 60%,#060608 100%);
border:1px solid rgba(232,0,13,.25);
padding:24px 20px 20px;
margin-bottom:14px;
}
.home-hero::before{
content:’’;position:absolute;inset:0;
background-image:
linear-gradient(rgba(232,0,13,.05) 1px,transparent 1px),
linear-gradient(90deg,rgba(232,0,13,.05) 1px,transparent 1px);
background-size:40px 40px;
mask-image:radial-gradient(ellipse 90% 80% at 50% 100%,black,transparent);
}
.home-hero-glow{
position:absolute;bottom:-20px;left:50%;transform:translateX(-50%);
width:280px;height:140px;border-radius:50%;
background:radial-gradient(ellipse,rgba(232,0,13,.2),transparent 70%);
pointer-events:none;
}
.hero-eyebrow{
display:inline-flex;align-items:center;gap:6px;
background:var(–red);
font-family:var(–font-label);font-size:9px;font-weight:700;letter-spacing:3px;
padding:3px 10px 3px 8px;margin-bottom:14px;
clip-path:polygon(0 0,100% 0,96% 100%,0 100%);
}
.hero-title{
font-family:var(–font-rock);
font-size:clamp(34px,10vw,52px);
line-height:.88;letter-spacing:2px;
text-shadow:0 0 40px rgba(232,0,13,.45),4px 4px 0 #000;
position:relative;z-index:1;
}
.hero-title .r{color:var(–red);}
.hero-tagline{
font-size:12px;font-weight:900;
border-left:2px solid var(–red);padding-left:10px;
margin-top:12px;line-height:1.5;
position:relative;z-index:1;
}
.hero-chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;position:relative;z-index:1;}
.hchip{
background:rgba(255,255,255,.06);border:1px solid var(–border);
padding:5px 10px;border-radius:6px;
}
.hchip .cl{font-family:var(–font-label);font-size:9px;color:var(–muted);letter-spacing:1px;}
.hchip .cv{font-family:var(–font-label);font-size:13px;color:var(–gold);font-weight:700;}

.hero-btn{
display:flex;align-items:center;justify-content:center;gap:8px;
margin-top:16px;
background:var(–red);color:#fff;
font-family:var(–font-label);font-size:11px;font-weight:700;letter-spacing:2px;
padding:12px;border-radius:8px;
text-decoration:none;
transition:opacity .2s,transform .1s;
position:relative;z-index:1;
}
.hero-btn:active{opacity:.8;transform:scale(.98);}

/* ARTIST PILLS */
.artist-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.artist-pill{
background:var(–card);border:1px solid var(–border);
border-radius:12px;overflow:hidden;
text-decoration:none;color:inherit;
transition:transform .15s,border-color .2s;
display:block;
-webkit-tap-highlight-color:transparent;
}
.artist-pill:active{transform:scale(.96);}
.artist-img{
height:80px;background-size:cover;background-position:center 20%;
position:relative;overflow:hidden;background-color:#1a0005;
}
.artist-img::after{
content:’’;position:absolute;inset:0;
background:linear-gradient(0deg,rgba(10,10,18,.98) 0%,transparent 70%);
}
.artist-pill-label{padding:10px 12px;}
.apl-role{font-family:var(–font-label);font-size:9px;color:var(–red);letter-spacing:2px;margin-bottom:2px;}
.apl-name{font-family:var(–font-rock);font-size:15px;}
.apl-links{display:flex;gap:4px;margin-top:6px;flex-wrap:wrap;}
.apl-link{
font-family:var(–font-label);font-size:9px;font-weight:700;letter-spacing:1px;
padding:2px 7px;border:1px solid;border-radius:3px;
text-decoration:none;transition:background .15s;
}
.apl-link.r{border-color:var(–red);color:var(–red);}
.apl-link.r:active{background:var(–red);color:#fff;}
.apl-link.o{border-color:var(–orange);color:var(–orange);}
.apl-link.o:active{background:var(–orange);color:#fff;}
.apl-link.g{border-color:#444;color:#888;}
.apl-link.g:active{background:#333;color:#ccc;}

/* GUEST STRIP */
.guest-strip{
background:rgba(176,106,255,.06);
border:1px solid rgba(176,106,255,.2);border-left:3px solid var(–purple);
border-radius:10px;padding:12px 14px;margin-bottom:14px;
}
.gs-label{font-family:var(–font-label);font-size:9px;letter-spacing:3px;color:var(–purple);margin-bottom:8px;}
.gs-chips{display:flex;gap:6px;flex-wrap:wrap;}
.gs-chip{
background:rgba(176,106,255,.1);border:1px solid rgba(176,106,255,.25);
border-radius:8px;padding:6px 10px;
}
.gs-chip .gn{font-size:12px;font-weight:700;}
.gs-chip .gf{font-size:10px;color:#666;}

/* QUICK STATS */
.qstats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px;}
.qstat{
background:var(–card);border:1px solid var(–border);
border-radius:12px;padding:14px 10px;text-align:center;
cursor:pointer;transition:transform .15s,border-color .2s;
}
.qstat:active{transform:scale(.94);}
.qstat .qv{font-family:var(–font-rock);font-size:22px;line-height:1;}
.qstat .ql{font-family:var(–font-label);font-size:9px;color:var(–muted);letter-spacing:1px;margin-top:4px;}

/* ══════════════════════════════════════
PLAN SCREEN (Timeline)
══════════════════════════════════════ */
.plan-header{
background:var(–card);border:1px solid var(–border);border-radius:14px;
padding:14px 16px;margin-bottom:14px;
}
.route-scroll{display:flex;align-items:center;gap:4px;overflow-x:auto;padding-bottom:2px;}
.route-scroll::-webkit-scrollbar{display:none;}
.rnode{
white-space:nowrap;font-family:var(–font-label);font-size:11px;font-weight:700;
padding:5px 10px;border:1px solid var(–border);border-radius:6px;
background:var(–bg2);flex-shrink:0;
}
.rnode.s{border-color:var(–orange);color:var(–orange);}
.rnode.l{border-color:var(–red);color:var(–red);}
.rarrow{color:#333;font-size:12px;flex-shrink:0;}

.tl-wrap{position:relative;padding-left:42px;}
.tl-axis{position:absolute;left:16px;top:0;bottom:0;width:1px;background:var(–border);}
.tl-item{position:relative;margin-bottom:10px;}
.tl-dot{
position